<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f0f1a">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Movile2 Bot"
            android:textSize="22sp"
            android:textColor="#4fc3f7"
            android:textStyle="bold"
            android:paddingBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Imposta prima i permessi, poi configura le coordinate"
            android:textSize="12sp"
            android:textColor="#888888"
            android:paddingBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btnOverlayPermission"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="1. Permesso Overlay"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnAccessibility"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="2. Accessibilità"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚠ Su MIUI/Samsung: Impostazioni › Accessibilità › App installate ›
abilita Movile2 Bot (non usare il menu principale Accessibilità)"
            android:textSize="11sp"
            android:textColor="#ffcc00"
            android:padding="8dp"
            android:background="#1a1a00"
            android:layout_marginBottom="12dp" />

        <!-- ── Mostro e Limite ────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎯 Mostro e Limite"
            android:textSize="15sp"
            android:textColor="#4fc3f7"
            android:textStyle="bold"
            android:paddingTop="4dp"
            android:paddingBottom="8dp" />

        <EditText
            android:id="@+id/etMonsterName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nome mostro (opzionale, per ricerca UI)"
            android:textColorHint="#666"
            android:textColor="#ffffff"
            android:background="#1e1e3a"
            android:padding="10dp"
            android:layout_marginBottom="8dp"
            android:inputType="text" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Max uccisioni:"
                android:textColor="#cccccc"
                android:gravity="center_vertical" />

            <EditText
                android:id="@+id/etMaxKills"
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:textColor="#ffffff"
                android:background="#1e1e3a"
                android:padding="8dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Timer sessione (min, 0=infinito):"
                android:textColor="#cccccc"
                android:gravity="center_vertical" />

            <EditText
                android:id="@+id/etSessionMinutes"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:textColor="#ffffff"
                android:background="#1e1e3a"
                android:padding="8dp"
                android:text="0" />
        </LinearLayout>

        <!-- ── Barra HP ───────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="❤ Barra HP (top-left)"
            android:textSize="15sp"
            android:textColor="#4fc3f7"
            android:textStyle="bold"
            android:paddingBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tocca il bordo sinistro della barra HP a vita piena. Il bot monitorerà la tua vita: pozione automatica se scende sotto soglia, modalità difesa se continua a calare."
            android:textSize="11sp"
            android:textColor="#aaaaaa"
            android:paddingBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Bordo sinistro barra HP:"
                android:textColor="#cccccc"
                android:gravity="center_vertical" />

            <TextView
                android:id="@+id/tvHpBarCoord"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="non impostato"
                android:textColor="#ef9a9a"
                android:gravity="center_vertical" />

            <Button
                android:id="@+id/btnPickHpBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Imposta"
                android:textSize="12sp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Larghezza barra piena (px):"
                android:textColor="#cccccc"
                android:gravity="center_vertical" />

            <EditText
                android:id="@+id/etHpBarFullWidth"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:textColor="#ffffff"
                android:background="#1e1e3a"
                android:padding="8dp"
                android:text="180" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Soglia pozione HP (%, es. 85):"
                android:textColor="#cccccc"
                android:gravity="center_vertical" />

            <EditText
                android:id="@+id/etHpPotionThreshold"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:textColor="#ffffff"
                android:background="#1e1e3a"
                android:padding="8dp"
                android:text="85" />
        </LinearLayout>

        <!-- ── Raggio Difesa ─────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🛡 Raggio Difesa (mostri vicini)"
            android:textSize="15sp"
            android:textColor="#4fc3f7"
            android:textStyle="bold"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tocca il centro del tuo personaggio sullo schermo. In modalità DIFESA il bot tappa in cerchio intorno a te con il raggio specificato, colpendo i mostri vicini anche senza selezionarli. Senza raggio configurato attacca solo col tasto attacco."
            android:textSize="11sp"
            android:textColor="#aaaaaa"
            android:paddingBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Centro personaggio:"
                android:textColor="#cccccc"
                android:gravity="center_vertical" />

            <TextView
                android:id="@+id/tvPlayerCoord"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="non impostato"
                android:textColor="#ef9a9a"
                android:gravity="center_vertical" />

            <Button
                android:id="@+id/btnPickPlayer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Imposta"
                android:textSize="12sp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Raggio difesa (px, es. 200):"
                android:textColor="#cccccc"
                android:gravity="center_vertical" />

            <EditText
                android:id="@+id/etDefenseRadius"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:textColor="#ffffff"
                android:background="#1e1e3a"
                android:padding="8dp"
                android:text="200" />
        </LinearLayout>

        <!-- ── Joystick Movimento ─────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🕹 Joystick Movimento"
            android:textSize="15sp"
            android:textColor="#4fc3f7"
            android:textStyle="bold"
            android:paddingBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tocca il centro del joystick nel gioco. Il bot pattuglia N→E→S→W automaticamente."
            android:textSize="11sp"
            android:textColor="#aaaaaa"
            android:paddingBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Centro joystick:"
                android:textColor="#cccccc"
                android:gravity="center_vertical" />

            <TextView
                android:id="@+id/tvJoystickCoord"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="non impostato"
                android:textColor="#80cbc4"
                android:gravity="center_vertical" />

            <Button
                android:id="@+id/btnPickJoystick"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Imposta"
                android:textSize="12sp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Raggio spinta (px):"
                android:textColor="#cccccc"
                android:gravity="center_vertical" />

            <EditText
                android:id="@+id/etJoystickRadius"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:textColor="#ffffff"
                android:background="#1e1e3a"
                android:padding="8dp"
                android:text="55" />
        </LinearLayout>

        <!-- ── Rotazione Visuale / Camera ─────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="👁 Rotazione Visuale"
            android:textSize="15sp"
            android:textColor="#4fc3f7"
            android:textStyle="bold"
            android:paddingBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tocca il centro dell'area che muove la visuale. Ogni 4 cicli il bot ruota la telecamera destra↔sinistra, ma solo se non ha già un bersaglio visibile."
            android:textSize="11sp"
            android:textColor="#aaaaaa"
            android:paddingBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Punto visuale:"
                android:textColor="#cccccc"
                android:gravity="center_vertical" />

            <TextView
                android:id="@+id/tvCameraCoord"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="non impostato"
                android:textColor="#80cbc4"
                android:gravity="center_vertical" />

            <Button
                android:id="@+id/btnPickCamera"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Imposta"
                android:textSize="12sp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Ampiezza swipe (px):"
                android:textColor="#cccccc"
                android:gravity="center_vertical" />

            <EditText
                android:id="@+id/etCameraSwipeRange"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:textColor="#ffffff"
                android:background="#1e1e3a"
                android:padding="8dp"
                android:text="80" />
        </LinearLayout>

        <!-- ── Attacco ────────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚔ Attacco"
            android:textSize="15sp"
            android:textColor="#4fc3f7"
            android:textStyle="bold"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Bottone attacco:"
                android:textColor="#cccccc"
                android:gravity="center_vertical" />

            <TextView
                android:id="@+id/tvAttackCoord"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="(950, 700)"
                android:textColor="#80cbc4"
                android:gravity="center_vertical" />

            <Button
                android:id="@+id/btnPickAttack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Imposta"
                android:textSize="12sp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Velocità loop (ms):"
                android:textColor="#cccccc"
                android:gravity="center_vertical" />

            <EditText
                android:id="@+id/etAttackDelay"
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:textColor="#ffffff"
                android:background="#1e1e3a"
                android:padding="8dp" />
        </LinearLayout>

        <!-- ── Abilità ────────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✨ Abilità"
            android:textSize="15sp"
            android:textColor="#4fc3f7"
            android:textStyle="bold"
            android:paddingBottom="8dp" />

        <!-- Abilità 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Abilità 1:"
                android:textColor="#cccccc"
                android:gravity="center_vertical" />

            <TextView
                android:id="@+id/tvSkill1Coord"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="(850, 650)"
                android:textColor="#80cbc4"
                android:gravity="center_vertical" />

            <Button
                android:id="@+id/btnPickSkill1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Imposta"
                android:textSize="12sp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Cooldown Abilità 1 (sec):"
                android:textColor="#cccccc"
                android:gravity="center_vertical" />

            <EditText
                android:id="@+id/etSkill1Cd"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:textColor="#ffffff"
                android:background="#1e1e3a"
                android:padding="8dp" />
        </LinearLayout>

        <!-- Abilità 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Abilità 2:"
                android:textColor="#cccccc"
                android:gravity="center_vertical" />

            <TextView
                android:id="@+id/tvSkill2Coord"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="(780, 720)"
                android:textColor="#80cbc4"
                android:gravity="center_vertical" />

            <Button
                android:id="@+id/btnPickSkill2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Imposta"
                android:textSize="12sp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Cooldown Abilità 2 (sec):"
                android:textColor="#cccccc"
                android:gravity="center_vertical" />

            <EditText
                android:id="@+id/etSkill2Cd"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:textColor="#ffffff"
                android:background="#1e1e3a"
                android:padding="8dp" />
        </LinearLayout>

        <!-- Abilità 3 (opzionale) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Abilità 3 (opzionale):"
                android:textColor="#cccccc"
                android:gravity="center_vertical" />

            <TextView
                android:id="@+id/tvSkill3Coord"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="non impostato"
                android:textColor="#80cbc4"
                android:gravity="center_vertical" />

            <Button
                android:id="@+id/btnPickSkill3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Imposta"
                android:textSize="12sp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Cooldown Abilità 3 (sec):"
                android:textColor="#cccccc"
                android:gravity="center_vertical" />

            <EditText
                android:id="@+id/etSkill3Cd"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:textColor="#ffffff"
                android:background="#1e1e3a"
                android:padding="8dp"
                android:text="8" />
        </LinearLayout>

        <!-- Abilità 4 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Abilità 4 (opzionale):"
                android:textColor="#cccccc"
                android:gravity="center_vertical" />

            <TextView
                android:id="@+id/tvSkill4Coord"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="non impostato"
                android:textColor="#80cbc4"
                android:gravity="center_vertical" />

            <Button
                android:id="@+id/btnPickSkill4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Imposta"
                android:textSize="12sp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Cooldown Abilità 4 (sec):"
                android:textColor="#cccccc"
                android:gravity="center_vertical" />

            <EditText
                android:id="@+id/etSkill4Cd"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:textColor="#ffffff"
                android:background="#1e1e3a"
                android:padding="8dp"
                android:text="12" />
        </LinearLayout>

        <!-- Abilità 5 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Abilità 5 (opzionale):"
                android:textColor="#cccccc"
                android:gravity="center_vertical" />

            <TextView
                android:id="@+id/tvSkill5Coord"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="non impostato"
                android:textColor="#80cbc4"
                android:gravity="center_vertical" />

            <Button
                android:id="@+id/btnPickSkill5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Imposta"
                android:textSize="12sp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Cooldown Abilità 5 (sec):"
                android:textColor="#cccccc"
                android:gravity="center_vertical" />

            <EditText
                android:id="@+id/etSkill5Cd"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:textColor="#ffffff"
                android:background="#1e1e3a"
                android:padding="8dp"
                android:text="15" />
        </LinearLayout>

        <!-- ── Pozioni ────────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🧪 Pozioni"
            android:textSize="15sp"
            android:textColor="#4fc3f7"
            android:textStyle="bold"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Slot pozione:"
                android:textColor="#cccccc"
                android:gravity="center_vertical" />

            <TextView
                android:id="@+id/tvPotionCoord"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="(0, 0)"
                android:textColor="#80cbc4"
                android:gravity="center_vertical" />

            <Button
                android:id="@+id/btnPickPotion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Imposta"
                android:textSize="12sp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Pozioni per slot:"
                android:textColor="#cccccc"
                android:gravity="center_vertical" />

            <EditText
                android:id="@+id/etMaxPotions"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:textColor="#ffffff"
                android:background="#1e1e3a"
                android:padding="8dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Pozione riserva (inventario):"
                android:textColor="#cccccc"
                android:gravity="center_vertical" />

            <TextView
                android:id="@+id/tvBackupPotionCoord"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="(0, 0)"
                android:textColor="#80cbc4"
                android:gravity="center_vertical" />

            <Button
                android:id="@+id/btnPickBackup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Imposta"
                android:textSize="12sp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />
        </LinearLayout>

        <!-- ── Salva + Overlay ────────────────────────────────────────────── -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💾 SALVA IMPOSTAZIONI"
            android:backgroundTint="#1565c0"
            android:textColor="#ffffff"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnStartOverlay"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="▶ Avvia Overlay"
                android:backgroundTint="#2e7d32"
                android:textColor="#ffffff" />

            <Button
                android:id="@+id/btnStopOverlay"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="■ Ferma Overlay"
                android:backgroundTint="#b71c1c"
                android:textColor="#ffffff" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
